model Claim {
  id            Int       @id @default(autoincrement())
  reference     String    @unique
  status        Status    @default(OPEN)
  vehicle       String
  description   String?
  expert        Expert    @relation(fields: [expertId], references: [id])
  expertId      Int
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum Status {
  OPEN
  CLOSED
}
